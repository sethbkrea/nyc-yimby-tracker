# NextAuth (Google sign-in, domain-restricted)
AUTH_SECRET=                       # `openssl rand -base64 32`
AUTH_GOOGLE_ID=                    # Google Cloud OAuth client ID
AUTH_GOOGLE_SECRET=                # Google Cloud OAuth client secret
ALLOWED_EMAIL_DOMAIN=bkrea.com     # only emails on this domain may sign in

# Public GitHub repo holding the scraper + articles.json
GITHUB_OWNER=sethbkrea
GITHUB_REPO=nyc-yimby-tracker

# Token used ONLY to trigger workflow_dispatch + read runs API.
# Needs `workflow` + `repo` scope.
GH_TOKEN=
