# NextAuth
AUTH_SECRET=                       # `openssl rand -base64 32`
AUTH_GOOGLE_ID=                    # Google Cloud OAuth client ID
AUTH_GOOGLE_SECRET=                # Google Cloud OAuth client secret
ALLOWED_EMAILS=                    # Comma-separated emails permitted to use the app

# GitHub: used both to dispatch workflows AND to fetch articles.json
GITHUB_OWNER=sethbkrea
GITHUB_REPO=nyc-yimby-tracker
GH_TOKEN=                          # Fine-grained PAT with actions:write + contents:read on the repo
